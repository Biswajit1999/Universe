# ─────────────────────────────────────────────────────────────
# UNIVERSE — environment variables
# Copy this file to .env.local and fill in what you have.
# EVERYTHING IS OPTIONAL: with no keys, UNIVERSE runs in Demo Mode
# using bundled demo datasets and the offline mock AI provider.
# ─────────────────────────────────────────────────────────────

# ── NASA (free key: https://api.nasa.gov) ──
# Used by: /api/apod (Astronomy Picture of the Day), /api/neo (Near-Earth Objects)
NASA_API_KEY=

# ── Gemini / Firebase AI Logic (https://aistudio.google.com/apikey) ──
# Used by: /api/ai — the "Hey Universe" assistant. Without it, the
# assistant uses the built-in offline mock provider (clearly labelled Demo).
GEMINI_API_KEY=
# Model to use when the key is present
GEMINI_MODEL=gemini-2.0-flash

# ── Firebase (https://console.firebase.google.com → Project settings → Web app) ──
# Used by: Auth (Google sign-in) + Firestore (Personal Vault).
# Without these, the Vault stores data in localStorage (Demo Mode).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── GitHub (optional, raises rate limits for the activity card) ──
GITHUB_TOKEN=
# Public username shown on the Command Center GitHub card
NEXT_PUBLIC_GITHUB_USERNAME=biswajitjana
